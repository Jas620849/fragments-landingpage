# Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# Google Analytics 4 Measurement ID
# Get this from https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-L08PV8DR2X

# Google Tag Manager Container ID
# Get this from https://tagmanager.google.com/
NEXT_PUBLIC_GTM_ID=GTM-5LXD6KQ5

# Microsoft Clarity Project ID
# Get this from https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_ID=

# Google Search Console Verification
# Get this from https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools Verification
# Get this from https://www.bing.com/webmasters/
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Demo Video URL (optional)
# URL to a demo video for the homepage
NEXT_PUBLIC_HOMEPAGE_DEMO_VIDEO_URL=

# Site Configuration
# Base URL for the site (required for SEO, sitemap, and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://fragmenttrails.com
